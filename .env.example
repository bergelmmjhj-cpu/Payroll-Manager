NODE_ENV=production
PORT=8080
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/payroll_manager
SESSION_SECRET=replace-with-a-long-random-secret
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
APP_ORIGIN=https://your-app.up.railway.app
# Optional when you need an explicit callback URL override.
# GOOGLE_CALLBACK_URL=https://your-app.up.railway.app/api/auth/google/callback
# Optional only when the frontend is hosted on a different origin.
# VITE_API_BASE_URL=https://your-api.up.railway.app

# External data integrations
WEEKDAYS_API_KEY=your-weekdays-crm-api-key
# WEEKDAYS_API_BASE_URL=https://app.weekdays.io/api  # override if needed
WFCONNECT_API_KEY=your-wfconnect-api-key
# WFCONNECT_API_BASE_URL=https://guide.wfconnect.org  # override if needed

# Optional: legacy sync from a Render PostgreSQL database
# RENDER_DATABASE_URL=postgresql://user:pass@host/dbname
